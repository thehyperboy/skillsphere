# SkillSphere Backend Environment Variables — EXAMPLE
# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/skillsphere?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your-db-password

# JWT (256-bit Base64-encoded secret key)
SKILLSPHERE_JWT_SECRET=your-base64-encoded-jwt-secret

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
